/* CRAW-mountlist - the CCON handler's RAW: counterpart.
**
** Same binary as CCON:, second device: the Startup string tells
** this instance to open its streams in raw mode, like RAW: does
** for CON:. Cooked mode is still one SetMode away.
**
** Install:  copy ccon-handler to L:      (shared with CCON:)
**           copy CRAW-mountlist to DEVS:
** Mount:    Mount CRAW: FROM DEVS:CRAW-mountlist
** Test:     type something >CRAW:10/10/400/120/raw/WAIT
*/

CRAW:
    Handler = L:ccon-handler
    StackSize = 8192
    Priority = 5
    GlobVec = -1
    Startup = "RAW"
#
