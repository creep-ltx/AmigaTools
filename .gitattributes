# Amiga executables committed to the repo -- never treat as text
/dupfind/dupfind binary
/amifetch/amifetch binary
/mv/mv binary
/mv/mv-asm binary
/cmenu/cmenu binary
/cfile/cfile binary
/cterm/cterm binary
/cterm/contest binary

# Amiga E sources: GitHub's default guess for .e is Eiffel
*.e linguist-language=E

# ANSI art: escape bytes, never diff as text
/cmenu/Headers/*.ANS binary
/cmenu/Libs/ptreplay.library binary

# CFile's frame mockups are ISO-8859-1 -- keep the bytes exact
/cfile/layout binary
/cfile/console-and-view-layout binary

# CCON's console test files are fed to the console byte-for-byte --
# escape sequences, and bare CRs that are overprints, not line ends
/ccon/tests/ccon-b1-fill binary
/ccon/tests/ccon-bisect binary
/ccon/tests/ccon-ichdch binary
/ccon/tests/ccon-osc binary
/ccon/tests/ccon-progress binary
/ccon/tests/ccon-styles binary

# CTerm's art mockups are raw high-bit bytes -- keep them exact
/cterm/cterm-mockup binary
/cterm/cterm-mockup-microknight7 binary
