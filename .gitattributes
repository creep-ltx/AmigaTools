# Amiga executables committed to the repo -- never treat as text
/dupfind/dupfind binary
/amifetch/amifetch binary
/mv/mv binary
/mv/mv-asm binary
/cmenu/cmenu binary
/cfile/cfile binary

# Amiga E sources: GitHub's default guess for .e is Eiffel
*.e linguist-language=E

# ANSI art: escape bytes, never diff as text
/cmenu/Headers/*.ANS binary
/cmenu/Libs/ptreplay.library binary

# CFile's frame mockup is ISO-8859-1 -- keep the bytes exact
/cfile/layout binary
